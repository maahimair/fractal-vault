# Gateway port
GATEWAY_PORT=3000


# ── Flask Backend ─────────────────────────────────────────────
# Must match INTERNAL_API_KEY above exactly
FLASK_INTERNAL_API_KEY=aebcca390c2f95c0c2cee28fde8701a3cf856a96466e4834c9c92579b7face74c24939134e74494952bfd47c01cf55d942db50f4239203f57735e40421b5123c

