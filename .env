INTERNAL_API_KEY=aebcca390c2f95c0c2cee28fde8701a3cf856a96466e4834c9c92579b7face74c24939134e74494952bfd47c01cf55d942db50f4239203f57735e40421b5123c

# Demo credentials for /token endpoint
DEMO_USER=fractal_admin
DEMO_PASS=MyStr0ngPassword123!

# Flask backend URL (as seen from Node gateway)
BACKEND_URL=http://127.0.0.1:5000

# Allowed CORS origins (comma-separated, no spaces)
