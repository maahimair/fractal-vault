JWT_SECRET=d3490726413f66a7a8d11a0219436be2311db2a5159014158192f3f84ae44eff99adfa48ebe6a173f8aab4076634a38bb009f44a3de81e28dd8c83b7b3c575c8

# Shared key between Node gateway and Flask backend (internal traffic only)
